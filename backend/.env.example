# LLM Provider (Google Gemini - primary)
GOOGLE_API_KEY=your_gemini_api_key_here

# Groq - fallback LLM (30 req/min free) — get at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Bright Data ($250 Hackathon Credit)
BRIGHT_DATA_API_TOKEN=your_bright_data_token_here
BRIGHT_DATA_SERP_ZONE=serp
BRIGHT_DATA_WEB_UNLOCKER_ZONE=web_unlocker

# CRM (optional — HubSpot Free Tier)
HUBSPOT_API_KEY=

# App Settings
APP_ENV=development
DEMO_MODE=False
